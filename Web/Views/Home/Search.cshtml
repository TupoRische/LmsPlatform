@foreach (var item in Model)
{
    <div class="col-md-6 col-lg-4 mb-5">
        <div class="card h-100 border-0 shadow-sm" style="border-radius: 20px;">
            <div class="card-body p-4 d-flex flex-column">

                @if (item.Type == "Profession")
                {
                    <span class="badge bg-primary-subtle text-primary mb-2 w-fit" style="width:fit-content">Професия</span>
                    <h4 class="fw-bold">@item.Title</h4>
                    <p class="text-muted small">@item.Description</p>
                    <a href="@item.Url" class="btn btn-primary rounded-pill mt-auto">Виж детайли</a>
                }
                else if (item.Type == "School")
                {
                    <span class="badge bg-warning-subtle text-warning mb-2 w-fit" style="width:fit-content; color: #856404 !important;">Училище</span>
                    <h4 class="fw-bold">@item.Title</h4>
                    <p class="text-muted small">@item.Description</p>
                    <a href="@item.Url" class="btn btn-warning rounded-pill mt-auto text-dark">Намери в списъка</a>
                }
                else if (item.Type == "Material")
                {
                    <span class="badge bg-success-subtle text-success mb-2 w-fit" style="width:fit-content">Материал</span>
                    <h4 class="fw-bold">@item.Title</h4>
                    <p class="text-muted small">📚 Дигитален ресурс за обучение</p>
                    <a href="@item.Url" class="btn btn-success rounded-pill mt-auto">Отвори материала</a>
                }

            </div>
        </div>
    </div>
}