@model Core.ViewModels.Teacher.Materials.TeacherMaterialsMyVm

@{
    ViewData["Title"] = "Моите материали";
}

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="page-title mb-1">Моите материали</h2>
            <p class="text-muted mb-0">Управлявайте качените от вас учебни материали.</p>
        </div>

        <a class="btn btn-primary px-4"
           asp-area="Teacher"
           asp-controller="Materials"
           asp-action="Create">
            <i class="bi bi-plus-lg me-1"></i>
            Добави материал
        </a>
    </div>

    @if (!Model.Materials.Any())
    {
        <div class="card shadow-sm border-0 empty-state-card">
            <div class="card-body p-4 text-center">
                <i class="bi bi-journal-x empty-icon"></i>
                <h5 class="mt-3 mb-2">Няма добавени материали</h5>
                <p class="text-muted mb-3">
                    Все още не сте качили учебни материали.
                </p>
                <a class="btn btn-primary"
                   asp-area="Teacher"
                   asp-controller="Materials"
                   asp-action="Create">
                    Добави първия материал
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 materials-table-card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table align-middle materials-table mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Заглавие</th>
                                <th>Създадено на</th>
                                <th class="text-end pe-4">Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in Model.Materials)
                            {
                                <tr>
                                    <td class="ps-4 fw-semibold material-title-cell">
                                        @m.Title
                                    </td>
                                    <td class="text-muted">
                                        @m.CreatedOn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="d-flex flex-wrap justify-content-end gap-2">
                                            <a class="btn btn-sm btn-outline-primary"
                                               asp-area="Teacher"
                                               asp-controller="Materials"
                                               asp-action="Details"
                                               asp-route-id="@m.Id">
                                                Детайли
                                            </a>

                                            <a class="btn btn-sm btn-outline-secondary"
                                               asp-area="Teacher"
                                               asp-controller="Materials"
                                               asp-action="Edit"
                                               asp-route-id="@m.Id">
                                                Редактиране
                                            </a>

                                            <form class="d-inline"
                                                  method="post"
                                                  asp-area="Teacher"
                                                  asp-controller="Materials"
                                                  asp-action="Delete"
                                                  asp-route-id="@m.Id">
                                                @Html.AntiForgeryToken()
                                                <button type="submit"
                                                        class="btn btn-sm btn-outline-danger"
                                                        onclick="return confirm('Сигурни ли сте, че искате да изтриете този материал?');">
                                                    Изтриване
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .page-title {
        font-weight: 700;
        color: #4a6285;
    }

    .materials-table-card,
    .empty-state-card {
        border-radius: 18px;
    }

    .materials-table thead th {
        background-color: #f8fafc;
        color: #4a6285;
        font-weight: 700;
        border-bottom: 1px solid #e2e8f0;
        padding-top: 1rem;
        padding-bottom: 1rem;
    }

    .materials-table tbody td {
        padding-top: 1rem;
        padding-bottom: 1rem;
        border-color: #eef2f7;
    }

    .materials-table tbody tr:hover {
        background-color: #fafcff;
    }

    .material-title-cell {
        color: #355070;
    }

    .empty-icon {
        font-size: 2.5rem;
        color: #94a3b8;
    }
</style>