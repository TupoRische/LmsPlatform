@using Core.ViewModels.Professions
@model ProfessionDetailsVm

@{
    Layout = "_Layout";
}

<div class="profession-details-container mb-5">
    <div class="details-hero-container">
        <div class="d-flex justify-content-between align-items-end flex-wrap gap-3 pb-3">
            <div class="hero-text-content">
                <span class="school-badge-pill">@Model.SchoolName</span>
                <h1 class="profession-main-title">@Model.Name</h1>
            </div>

            <div class="hero-action-content">
                <a class="btn-back-pill" asp-controller="Professions" asp-action="Index">
                    <i class="bi bi-arrow-left"></i> Назад към списъка
                </a>
            </div>
        </div>

        <div class="header-divider-line"></div>
    </div>

    <div class="row g-4">
        @* 2. Лява колона: Описание и План-конспект *@
        <div class="col-lg-4">
            <div class="info-card mb-4">
                <h4><i class="bi bi-info-circle me-2"></i>За професията</h4>
                @if (!string.IsNullOrWhiteSpace(Model.Description))
                {
                    <p>@Model.Description</p>
                }
                else
                {
                    <p class="text-muted italic">Няма добавено описание за тази професия.</p>
                }
            </div>

            @* Място за План-конспект *@
            <div class="info-card plan-section">
                <h4><i class="bi bi-journal-text me-2"></i>План-конспект</h4>
                <div class="plan-steps">
                    <div class="step">
                        <div class="step-number">01</div>
                        <div class="step-content">
                            <h6>Основни компетенции</h6>
                            <p>Тук ще научиш базовите принципи на работа в сектора.</p>
                        </div>
                    </div>
                    <div class="step">
                        <div class="step-number">02</div>
                        <div class="step-content">
                            <h6>Практически умения</h6>
                            <p>Работа с инструменти, софтуер и реални проекти.</p>
                        </div>
                    </div>
                    <div class="step">
                        <div class="step-number">03</div>
                        <div class="step-content">
                            <h6>Професионална етика</h6>
                            <p>Стандарти за качество и безопасност при работа.</p>
                        </div>
                    </div>
                </div>
                <div class="mt-3 text-center">
                    <small class="text-muted">* Пълният конспект ще бъде достъпен скоро.</small>
                </div>
            </div>
        </div>

        @* 3. Дясна колона: Презентация *@
        <div class="col-lg-8">
            <div class="presentation-card">
                <div class="card-header-custom">
                    <h4><i class="bi bi-projector me-2"></i>Интерактивна презентация</h4>
                    <span class="badge bg-light text-dark">PDF Преглед</span>
                </div>
                <div class="pdf-wrapper">
                    <iframe src="/presentations/@(Model.Id).pdf#toolbar=0&navpanes=0"
                            type="application/pdf">
                    </iframe>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    :root {
        --primary: #5c85b1; 
        --primary-light: #f4f8fc;
        --text-dark: #28496f;
        --text-muted: #6f86a0;
        --line: rgba(63, 110, 165, 0.12);
    }

    /* Hero Section */
    .details-hero-container {
        width: 100%;
        padding-top: 1rem;
        margin-bottom: 2rem;
    }

    .school-badge-pill {
        display: inline-block;
        background: white;
        color: var(--primary);
        padding: 4px 15px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.8rem;
        margin-bottom: 10px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.03);
        border: 1px solid var(--line);
    }

    .profession-main-title {
        color: var(--primary) !important;
        font-weight: 500 !important;
        margin: 0 !important;
        font-size: clamp(1.8rem, 4vw, 2.8rem) !important; 
        line-height: 1.2;
    }

    .btn-back-pill {
        text-decoration: none !important;
        color: var(--text-muted) !important;
        font-weight: 600;
        padding: 10px 20px;
        border-radius: 50px;
        background: white;
        border: 1px solid var(--line);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: 0.3s;
        box-shadow: 0 2px 8px rgba(0,0,0,0.03);
        white-space: nowrap;
    }

        .btn-back-pill:hover {
            background: var(--primary-light);
            color: var(--primary) !important;
            transform: translateY(-2px);
        }

    .header-divider-line {
        width: 100%;
        height: 1px;
        background-color: white;
        margin-top: 5px;
    }

  

    /* Карти */
    .info-card, .presentation-card {
        background: white;
        border-radius: 24px;
        border: 1px solid var(--line);
        box-shadow: 0 10px 25px rgba(40, 73, 111, 0.04);
        overflow: hidden;
    }

    .info-card {
        padding: 2rem;
    }

        .info-card h4 {
            color: var(--primary);
            font-weight: 700;
            font-size: 1.2rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
        }

    .plan-steps {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .step {
        display: flex;
        gap: 1rem;
        position: relative;
    }

    .step-number {
        background: var(--primary);
        color: white;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        font-size: 0.75rem;
        flex-shrink: 0;
        z-index: 2;
    }

    .step:not(:last-child)::after {
        content: '';
        position: absolute;
        left: 15px;
        top: 32px;
        bottom: -24px;
        width: 2px;
        background: var(--primary-light);
    }

    /* Презентация */
    .card-header-custom {
        padding: 1rem 1.5rem;
        background: var(--primary);
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .pdf-wrapper {
        height: 600px;
        background: #f8f9fa;
    }

        .pdf-wrapper iframe {
            width: 100%;
            height: 100%;
            border: none;
        }

</style>