@using Core.ViewModels.School
@using Core.ViewModels.Professions
@model Core.ViewModels.Admin.Professions.ProfessionsPageVm

@{
    var schools = ViewBag.Schools as IEnumerable<SchoolDropdownVm> ?? Enumerable.Empty<SchoolDropdownVm>();
    int? selected = ViewBag.SelectedSchoolId as int?;
}

<div class="teacher-edit-page px-4 py-3">
    <div class="teacher-edit-shell">

        <div class="professions-hero">
            <div>
                <span class="hero-kicker">Админ панел</span>
                <h1>Професии</h1>
                <p>Подреден преглед на професиите в системата, училищата към които принадлежат и наличните материали по всяка от тях.</p>
            </div>

            <a asp-area="Student"
               asp-controller="Professions"
               asp-action="Index"
               class="hero-link">
                Публичен списък
            </a>
        </div>

        <div class="professions-stats">
            <article class="stat-card">
                <span>Общо професии</span>
                <strong>@Model.TotalProfessions</strong>
            </article>
            <article class="stat-card">
                <span>Училища с професии</span>
                <strong>@Model.SchoolsRepresented</strong>
            </article>
            <article class="stat-card">
                <span>Професии с материали</span>
                <strong>@Model.WithMaterialsCount</strong>
            </article>
            <article class="stat-card">
                <span>Общо материали</span>
                <strong>@Model.TotalMaterials</strong>
            </article>
        </div>

        @* Филтриране 
        <div class="filter-wrapper p-4 mb-4 shadow-sm" style="background: #fdfdfd; border-radius: 18px; border: 1px solid var(--line);">
            <form method="get" class="row align-items-end g-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold small" style="color: var(--text);">ФИЛТРИРАЙ ПО УЧИЛИЩЕ</label>
                    <select class="form-select shadow-none" name="schoolId" style="border-radius: 10px; border-color: var(--line);">
                        <option value="">-- Всички училища --</option>
                        @foreach (var s in schools)
                        {
                            <option value="@s.Id" selected="@(selected == s.Id)">@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="edit-link w-100 border-0" style="height: 42px;">Търси</button>
                </div>
                <div class="col-md-3">
                    <a class="edit-link edit-link--soft w-100 text-center" style="height: 42px; display: block; line-height: 42px;" asp-action="Index">Изчисти</a>
                </div>
            </form>
        </div>*@

        @* Таблица *@
        <div class="table-responsive shadow-sm" style="border-radius: 15px; background: white; border: 1px solid var(--line);">
            <table class="table table-hover mb-0">
                <thead style="background: #f9fbfe;">
                    <tr>
                        <th class="ps-4 py-3" style="color: var(--text); border-bottom: none;">ПРОФЕСИЯ</th>
                        <th class="py-3" style="color: var(--text); border-bottom: none;">УЧИЛИЩЕ</th>
                        <th class="text-center py-3" style="color: var(--text); border-bottom: none;">МАТЕРИАЛИ</th>
                        <th class="text-end pe-4 py-3" style="border-bottom: none;">ДЕЙСТВИЯ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Professions)
                    {
                        <tr style="vertical-align: middle;">
                            <td class="ps-4 py-3 fw-bold" style="color: var(--text);">@p.Name</td>
                            <td class="py-3 text-muted">
                                <span class="badge-pill px-3 py-1" style="background: var(--accent-soft); color: var(--accent); border-radius: 8px; font-size: 0.85rem;">
                                    @p.SchoolName
                                </span>
                            </td>
                            <td class="text-center py-3">
                                <span class="fw-bold" style="color: var(--accent);">@p.MaterialsCount</span>
                            </td>
                            <td class="text-end pe-4 py-3">
                                <div class="d-flex justify-content-end gap-2">
                                    <a class="edit-link btn-sm py-1 px-3" style="font-size: 0.75rem; min-width: 80px;"
                                       asp-action="Details" asp-route-id="@p.Id">Детайли</a>

                                    <a class="edit-link edit-link--soft btn-sm py-1 px-3" style="font-size: 0.75rem; min-width: 80px; background: #fff3cd; color: #856404;"
                                       asp-action="Edit" asp-route-id="@p.Id">Редакция</a>

                                    <a class="edit-link edit-link--soft btn-sm py-1 px-3" style="font-size: 0.75rem; min-width: 80px; background: #f8d7da; color: #721c24;"
                                       asp-action="Delete" asp-route-id="@p.Id">Изтрий</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .professions-hero {
        background: linear-gradient(135deg, #f4f8fc 0%, #e8f0f9 100%);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 1.15rem 1.25rem;
        display: flex;
        justify-content: space-between;
        gap: 0.9rem;
        align-items: center;
        min-height: 148px;
        margin-bottom: 1rem;
    }

    .hero-kicker {
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.68rem;
        font-weight: 700;
        color: var(--accent);
        margin-bottom: 0.4rem;
    }

    .professions-hero h1 {
        margin: 0 0 0.25rem;
        color: var(--text);
        font-size: clamp(1.45rem, 2vw, 1.9rem);
    }

    .professions-hero p {
        margin: 0;
        max-width: 760px;
        color: var(--muted);
        line-height: 1.5;
        font-size: 0.88rem;
    }

    .hero-link {
        background: #5c85b1;
        color: white;
        text-decoration: none;
        padding: 0.58rem 0.82rem;
        border-radius: 999px;
        font-weight: 700;
        white-space: nowrap;
        font-size: 0.82rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .hero-link:hover,
        .hero-link:focus {
            background: var(--accent);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 12px 24px rgba(40, 73, 111, 0.16);
        }

    .professions-stats {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .stat-card {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 0.8rem 0.9rem;
        box-shadow: 0 10px 22px rgba(40, 73, 111, 0.04);
    }

        .stat-card span {
            display: block;
            color: var(--muted);
            font-size: 0.8rem;
            margin-bottom: 0.3rem;
        }

        .stat-card strong {
            color: var(--text);
            font-size: 1.3rem;
            line-height: 1;
        }

    /* Запазваме твоите основни променливи */
    .uppercase {
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .table thead th {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .edit-link {
        text-decoration: none;
        border-radius: 10px;
        transition: 0.2s all;
        display: inline-block;
        font-weight: 600;
    }

    /* Добавяме малко "въздух" на редовете */
    .table tbody tr:last-child td {
        border-bottom: none;
    }
</style>