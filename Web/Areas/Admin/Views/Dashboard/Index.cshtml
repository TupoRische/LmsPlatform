@model Core.ViewModels.Admin.AdminDashboardVm

<h2 class="mb-4">Администраторско табло</h2>
<hr />

<div class="row g-3">
    <div class="row g-4">
        <!-- Users -->
        <div class="col-md-3">
            <div class="card border-start border-primary border-4 shadow-sm h-100 dashboard-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-muted">Потребители</h6>
                            <h3>@Model.TotalUsers</h3>
                        </div>
                        <i class="bi bi-people fs-1 text-primary"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Teachers -->
        <div class="col-md-3">
            <div class="card border-start border-success border-4 shadow-sm h-100 dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted">Учители</h6>
                        <h3>@Model.Teachers</h3>
                    </div>
                    <i class="bi bi-person-badge fs-1 text-success"></i>
                </div>
            </div>
        </div>

        <!-- Students -->
        <div class="col-md-3">
            <div class="card border-start border-info border-4 shadow-sm h-100 dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted">Ученици</h6>
                        <h3>@Model.Students</h3>
                    </div>
                    <i class="bi bi-mortarboard fs-1 text-info"></i>
                </div>
            </div>
        </div>

        <!-- Pending -->
        <div class="col-md-3">
            <div class="card border-start border-warning border-4 shadow-sm h-100 dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted">
                            <a asp-area="Admin" asp-controller="TeacherRequests" asp-action="Index" class="text-decoration-none text-warning">Неодобрени учители</a>
                        </h6>
                        <h3>@Model.PendingTeachers</h3>
                    </div>
                    <i class="bi bi-hourglass-split fs-1 text-warning"></i>
                </div>
            </div>
        </div>
    </div>


    <div class="row g-4 mt-1">

        <!-- Schools -->
        <div class="col-md-3">
            <div class="card border-start border-secondary border-4 shadow-sm h-100 dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted">Училища</h6>
                        <h3>@Model.Schools</h3>
                    </div>
                    <i class="bi bi-building fs-1 text-secondary"></i>
                </div>
            </div>
        </div>

        <!-- Professions -->
        <div class="col-md-3">
            <div class="card border-start border-dark border-4 shadow-sm h-100 dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted">Професии</h6>
                        <h3>@Model.Professions</h3>
                    </div>
                    <i class="bi bi-briefcase fs-1 text-dark"></i>
                </div>
            </div>
        </div>

        <!-- Materials -->
        <div class="col-md-3">
            <div class="card border-start border-primary border-4 shadow-sm h-100 dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted">Материали</h6>
                        <h3>@Model.Materials</h3>
                    </div>
                    <i class="bi bi-journal-text fs-1 text-primary"></i>
                </div>
            </div>
        </div>

        <!-- Comments -->
        <div class="col-md-3">
            <div class="card border-start border-success border-4 shadow-sm h-100 dashboard-card">
                <div class="card-body d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted">Коментари</h6>
                        <h3>@Model.Comments</h3>
                    </div>
                    <i class="bi bi-chat-dots fs-1 text-success"></i>
                </div>
            </div>
        </div>

    </div>

    <hr class="my-4" />

    <h6>Teachers</h6>
    <h3>@Model.Teachers</h3>
    <canvas id="teachersMiniChart" height="40"></canvas>

    @if (Model.LatestPendingTeachers.Any())
    {
        <ul class="list-unstyled mt-2">
            @foreach (var u in Model.LatestPendingTeachers)
            {
                <li>
                    <a asp-area="Admin"
                       asp-controller="TeacherRequests"
                       asp-action="Index">
                        @u.FullName
                    </a>
                </li>
            }
        </ul>
    }
    else
    {
        <small class="text-muted">Няма изчакващи за одобрение</small>
    }
</div>

@* <div class="mt-4">
    <a class="btn btn-outline-primary" asp-area="Admin" asp-controller="TeacherRequests" asp-action="Index">
        Teacher Requests
    </a>
</div> *@


@section Scripts {
    <script>
        const ctx = document.getElementById('usersChart');

                new Chart(document.getElementById('teachersMiniChart'), {
            type: 'line',
            data: {
                labels: ['', '', '', '', '', ''],
                datasets: [{
                    data: [10, 12, 15, 18, 20, 22], // примерни данни
                    borderColor: '#198754',
                    tension: 0.4,
                    fill: false,
                    pointRadius: 0
                }]
            },
            options: {
                plugins: { legend: { display: false } },
                scales: {
                    x: { display: false },
                    y: { display: false }
                },
                maintainAspectRatio: false
            }
        });
    </script>
}