@model Core.ViewModels.Admin.AdminDashboardVm

<h2 class="mb-4">Администраторско табло</h2>
<hr />

<div class="row g-3">
    <div class="col-lg-3 col-md-6">
        <a asp-area="Admin"
           asp-controller="Users"
           asp-action="Index"
           class="text-decoration-none text-dark">

            <div class="card shadow-sm border-primary h-100 dashboard-card">
                <div class="card-body d-flex flex-column">

                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted mb-1">Потребители</h6>
                            <h3 class="mb-0">@Model.UsersCount</h3>
                        </div>
                        <i class="bi bi-people fs-2 text-primary"></i>
                    </div>

                    <hr />

                    <!-- Recent users -->
                    <div class="flex-grow-1">
                        @foreach (var user in Model.RecentUsers)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span>@user.FullName</span>
                                <span class="badge
                                @(user.Role switch
                                      {
                                          "Admin" => "bg-primary",
                                          "Teacher" => "bg-success",
                                          "Student" => "bg-info",
                                          _ => "bg-secondary"
                                      })">
                                @user.Role
                            </span>
                        </div>
                                                }
                    </div>

                </div>
            </div>

        </a>
    </div>

        <!-- Teachers -->
    <div class="col-lg-3 col-md-6">
        <a asp-area="Admin"
           asp-controller="Users"
           asp-action="Teachers"
           class="text-decoration-none text-dark">

            <div class="card shadow-sm border-success h-100 dashboard-card">
                <div class="card-body d-flex flex-column">

                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted mb-1">Учители</h6>
                            <h3 class="mb-0">@Model.Teachers</h3>
                        </div>
                        <i class="bi bi-person-badge fs-2 text-success"></i>
                    </div>

                    <hr />

                    <!-- Random teachers list -->
                    <div class="flex-grow-1">
                        @foreach (var teacher in Model.RandomTeachers)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span>@teacher.FullName</span>
                                <span class="badge bg-success">
                                    Teacher
                                </span>
                            </div>
                        }
                    </div>

                </div>
            </div>

        </a>
    </div>

        <!-- Students -->
    <div class="col-lg-3 col-md-6">
        <a asp-area="Admin"
           asp-controller="Users"
           asp-action="Students"
           class="text-decoration-none text-dark">

            <div class="card shadow-sm border-info h-100 dashboard-card">
                <div class="card-body d-flex flex-column">

                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted mb-1">Ученици</h6>
                            <h3 class="mb-0">@Model.Students</h3>
                        </div>
                        <i class="bi bi-mortarboard fs-2 text-info"></i>
                    </div>

                    <hr />

                    <!-- Random students -->
                    <div class="flex-grow-1">
                        @foreach (var student in Model.RandomStudents)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span>@student.FullName</span>
                                <span class="badge bg-info">
                                    Student
                                </span>
                            </div>
                        }
                    </div>

                </div>
            </div>

        </a>
        </div>

        <!-- Pending -->
    <div class="col-lg-3 col-md-6">
        <a asp-area="Admin"
           asp-controller="TeacherRequests"
           asp-action="Index"
           class="text-decoration-none text-dark">

            <div class="card shadow-sm border-warning h-100 dashboard-card">
                <div class="card-body d-flex flex-column">

                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-warning mb-1">
                                Неодобрени учители
                            </h6>
                            <h3 class="mb-0">
                                @Model.PendingTeachers
                            </h3>
                        </div>
                        <i class="bi bi-hourglass-split
                       fs-2 text-warning"></i>
                    </div>

                    <hr />

                    <!-- Preview -->
                    <div class="flex-grow-1">
                        @foreach (var teacher in Model.PendingTeachersPreview)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div>
                                    <div class="fw-semibold">
                                        @teacher.FullName
                                    </div>
                                    <div class="small text-muted">
                                        @teacher.Email
                                    </div>
                                </div>

                                <span class="badge bg-warning text-dark">
                                    @teacher.RequestedRole
                                </span>
                            </div>
                        }
                    </div>

                </div>
            </div>

        </a>
        </div>
    </div>


    <div class="row g-4 mt-1">

        <!-- Schools -->
    <div class="col-lg-3 col-md-6">
        <a asp-area="Admin"
           asp-controller="Schools"
           asp-action="Index"
           class="text-decoration-none text-dark">

            <div class="card shadow-sm border-secondary h-100 dashboard-card">
                <div class="card-body d-flex flex-column">

                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted mb-1">Училища</h6>
                            <h3 class="mb-0">@Model.Schools</h3>
                        </div>
                        <i class="bi bi-building fs-2 text-secondary"></i>
                    </div>

                    <hr />

                    <!-- Random schools -->
                    <div class="flex-grow-1">
                        <ol class="ps-3 mb-0">
                            @foreach (var school in Model.RandomSchools)
                            {
                                <li class="mb-2">
                                    <div class="school-name-short">
                                        @school.Abbreviation
                                    </div>
                                    <div class="small text-muted">
                                        @school.City
                                    </div>
                                </li>
                            }
                        </ol>
                    </div>

                </div>
            </div>

        </a>
        </div>

        <!-- Professions -->
    <div class="col-lg-3 col-md-6">
        <a asp-area="Admin"
           asp-controller="Professions"
           asp-action="Index"
           class="text-decoration-none text-dark">

            <div class="card shadow-sm border-dark h-100 dashboard-card">
                <div class="card-body d-flex flex-column">

                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted mb-1">Професии</h6>
                            <h3 class="mb-0">@Model.Professions</h3>
                        </div>
                        <i class="bi bi-briefcase fs-2 text-dark"></i>
                    </div>

                    <hr />

                    <!-- Random professions -->
                    <div class="flex-grow-1">
                        <ol class="ps-3 mb-0">
                            @foreach (var profession in Model.RandomProfessions)
                            {
                                <li class="mb-2">
                                    @profession.Name
                                </li>
                            }
                        </ol>
                    </div>

                </div>
            </div>

        </a>
        </div>

        <!-- Materials -->
    <div class="col-lg-3 col-md-6">
            <div class="card border-start border-primary border-4 shadow-sm h-100 dashboard-card">
            <div class="card-body py-3 px-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted">Материали</h6>
                        <h3>@Model.Materials</h3>
                    </div>
                <i class="bi bi-journal-text fs-3 text-primary"></i>
                </div>
            </div>
        </div>

        <!-- Comments -->
    <div class="col-lg-3 col-md-6">
            <div class="card border-start border-success border-4 shadow-sm h-100 dashboard-card">
            <div class="card-body py-3 px-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted">Коментари</h6>
                        <h3>@Model.Comments</h3>
                    </div>
                <i class="bi bi-chat-dots fs-3 text-success"></i>
                </div>
            </div>
        </div>

    </div>

    <hr class="my-4" />

    <h6>Teachers</h6>
    <h3>@Model.Teachers</h3>


    @if (Model.LatestPendingTeachers.Any())
    {
        <ul class="list-unstyled mt-2">
            @foreach (var u in Model.LatestPendingTeachers)
            {
                <li>
                    <a asp-area="Admin"
                       asp-controller="TeacherRequests"
                       asp-action="Index">
                        @u.FullName
                    </a>
                </li>
            }
        </ul>
    }
    else
    {
        <small class="text-muted">Няма изчакващи за одобрение</small>
    }

