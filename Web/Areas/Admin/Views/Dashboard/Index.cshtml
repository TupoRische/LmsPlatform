﻿@model Core.ViewModels.Admin.AdminDashboardVm

<h2 class="mb-4">Администраторско табло</h2>
<hr />

<div class="row g-3">
    <div class="col-lg-3 col-md-6">
        <a asp-area="Admin"
           asp-controller="Users"
           asp-action="Index"
           class="text-decoration-none text-dark">

            <div class="card shadow-sm border-primary h-100 dashboard-card">
                <div class="card-body d-flex flex-column">

                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted mb-1">Потребители</h6>
                            <h3 class="mb-0">@Model.UsersCount</h3>
                        </div>
                        <i class="bi bi-people fs-2 text-primary"></i>
                    </div>

                    <hr />

                    <!-- Recent users -->
                    <div class="flex-grow-1">
                        @foreach (var user in Model.RecentUsers)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span>@user.FullName</span>
                                <span class="badge
                                @(user.Role switch
                                      {
                                          "Admin" => "bg-primary",
                                          "Teacher" => "bg-success",
                                          "Student" => "bg-info",
                                          _ => "bg-secondary"
                                      })">
                                @user.Role
                            </span>
                        </div>
                                                }
                    </div>

                </div>
            </div>

        </a>
    </div>

        <!-- Teachers -->
    <div class="col-lg-3 col-md-6">
        <a asp-area="Admin"
           asp-controller="Users"
           asp-action="Teachers"
           class="text-decoration-none text-dark">

            <div class="card shadow-sm border-success h-100 dashboard-card">
                <div class="card-body d-flex flex-column">

                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted mb-1">Учители</h6>
                            <h3 class="mb-0">@Model.Teachers</h3>
                        </div>
                        <i class="bi bi-person-badge fs-2 text-success"></i>
                    </div>

                    <hr />

                    <!-- Random teachers list -->
                    <div class="flex-grow-1">
                        @foreach (var teacher in Model.RandomTeachers)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span>@teacher.FullName</span>
                                <span class="badge bg-success">
                                    Teacher
                                </span>
                            </div>
                        }
                    </div>

                </div>
            </div>

        </a>
    </div>

        <!-- Students -->
    <div class="col-lg-3 col-md-6">
        <a asp-area="Admin"
           asp-controller="Users"
           asp-action="Students"
           class="text-decoration-none text-dark">

            <div class="card shadow-sm border-info h-100 dashboard-card">
                <div class="card-body d-flex flex-column">

                    <!-- Header -->
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-muted mb-1">Ученици</h6>
                            <h3 class="mb-0">@Model.Students</h3>
                        </div>
                        <i class="bi bi-mortarboard fs-2 text-info"></i>
                    </div>

                    <hr />

                    <!-- Random students -->
                    <div class="flex-grow-1">
                        @foreach (var student in Model.RandomStudents)
                        {
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span>@student.FullName</span>
                                <span class="badge bg-info">
                                    Student
                                </span>
                            </div>
                        }
                    </div>

                </div>
            </div>

        </a>
        </div>

        <!-- Pending -->
    <div class="col-lg-3 col-md-6">
