@using Core.ViewModels.Admin.Users
@model UserEditVm

<div class="teacher-edit-page mb-4 student-theme">
    @* Добавяме клас student-theme за различен цвят, ако желаеш *@
    <div class="teacher-edit-shell">
        <div class="teacher-edit-head">
            <div>
                <span class="hero-kicker">Профил на ученик</span>
                <h1>Редакция</h1>
                <p>Актуализирай основните данни за ученика и неговото училище</p>
            </div>
        </div>

        <form asp-action="EditStudent" method="post" class="teacher-edit-form">
            <input type="hidden" asp-for="Id" />

            @* Използваме твоето partial view за самите полета (Име, Фамилия, Училище) *@
            <div class="form-grid">
                <partial name="UserEditForm" model="Model" />
            </div>

            <div class="teacher-edit-actions">
                <a asp-action="Students" class="edit-link edit-link--soft">Назад</a>
                <button type="submit" class="edit-link">Запази</button>
            </div>
        </form>
    </div>
</div>

