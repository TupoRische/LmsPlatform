﻿@using Core.ViewModels.Admin.Users
@model AdminUsersPageVm

<div class="admin-users-page mb-4">
    <div class="users-hero">
        <div>
            <span class="hero-kicker">Админ панел</span>
            <h1>Потребители</h1>
            <p>Преглед на всички акаунти в платформата с бърз контекст за роля, училище и статус на одобрение.</p>
        </div>
    </div>

    <div class="users-stats">
        <article class="stat-card">
            <span>Всички</span>
            <strong>@Model.TotalUsers</strong>
        </article>
        <article class="stat-card">
            <span>Администратори</span>
            <strong>@Model.AdminsCount</strong>
        </article>
        <article class="stat-card">
            <span>Учители</span>
            <strong>@Model.TeachersCount</strong>
        </article>
        <article class="stat-card">
            <span>Ученици</span>
            <strong>@Model.StudentsCount</strong>
        </article>
        <article class="stat-card stat-card--pending">
            <span>Чакащи учители</span>
            <strong>@Model.PendingTeachersCount</strong>
        </article>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-4 mb-4">
            @TempData["Error"]
        </div>
    }

    @if (!Model.Users.Any())
    {
        <div class="admin-empty-state">Все още няма потребители в системата.</div>
    }
    else
    {
        <div class="users-table-shell">
            <div class="users-table-head">
                <div>
                    <h2>Списък с акаунти</h2>
                    <p>Подредени са по най-новите регистрации, за да се ориентираш бързо в активността.</p>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table align-middle users-table mb-0">
                    <thead>
                        <tr>
                            <th>Потребител</th>
                            <th>Роля</th>
                            <th>Училище</th>
                            <th>Регистрация</th>
                            <th>Статус</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            var roleClass = user.Role switch
                            {
                                "Admin" => "role-pill role-pill--admin",
                                "Teacher" => "role-pill role-pill--teacher",
                                "Student" => "role-pill role-pill--student",
                                _ => "role-pill"
                            };

                            <tr>
                                <td>
                                    <div class="user-cell">
                                        <div class="user-avatar">
                                            @(string.IsNullOrWhiteSpace(user.FullName) ? "?" : user.FullName[..1].ToUpperInvariant())
                                        </div>

                                        <div>
                                            <div class="user-name">@user.FullName</div>
                                            <div class="user-email">@user.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="@roleClass">@user.Role</span>
                                </td>
                                <td>@user.SchoolName</td>
                                <td>@user.CreatedOn.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @if (user.Role == "Teacher" && !user.IsApproved)
                                    {
                                        <span class="status-pill status-pill--pending">Чака одобрение</span>
                                    }
                                    else
                                    {
                                        <span class="status-pill">Активен</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-sm admin-danger-btn"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal-@user.Id">
                                        Изтрий
                                    </button>

                                    <div class="modal fade" id="deleteModal-@user.Id" tabindex="-1" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content border-0 rounded-4 shadow">
                                                <div class="modal-header border-0">
                                                    <h5 class="modal-title">Потвърждение</h5>
                                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                </div>
                                                <div class="modal-body pt-0">
                                                    Сигурни ли сте, че искате да изтриете
                                                    <strong>@user.Email</strong>?
                                                </div>
                                                <div class="modal-footer border-0">
                                                    <button type="button" class="btn btn-light border rounded-pill px-3" data-bs-dismiss="modal">Отказ</button>
                                                    <form asp-action="Delete" method="post">
                                                        <input type="hidden" name="id" value="@user.Id" />
                                                        <button type="submit" class="btn admin-danger-btn rounded-pill px-3">
                                                            Да, изтрий
                                                        </button>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .admin-users-page {
        --accent: #3f6ea5;
        --accent-soft: #edf4fb;
        --beige-soft: #f6efe5;
        --line: rgba(63, 110, 165, 0.12);
        --text: #28496f;
        --muted: #6f86a0;
    }

    .users-hero,
    .users-table-shell,
    .stat-card,
    .admin-empty-state {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 18px;
        box-shadow: 0 10px 22px rgba(40, 73, 111, 0.04);
    }

    .users-hero {
        background: linear-gradient(135deg, #f4f8fc 0%, #f6efe5 100%);
        padding: 1.15rem 1.25rem;
        min-height: 148px;
        display: flex;
        align-items: center;
        margin-bottom: 1rem;
    }

    .hero-kicker {
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.68rem;
        font-weight: 700;
        color: var(--accent);
        margin-bottom: 0.4rem;
    }

    .users-hero h1 {
        margin: 0 0 0.25rem;
        color: var(--text);
        font-size: clamp(1.45rem, 2vw, 1.9rem);
    }

    .users-hero p {
        margin: 0;
        max-width: 760px;
        color: var(--muted);
        line-height: 1.5;
        font-size: 0.88rem;
    }

    .users-stats {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 0.75rem;
        margin-bottom: 1rem;
    }

    .stat-card {
        padding: 0.85rem 0.95rem;
    }

    .stat-card span {
        display: block;
        color: var(--muted);
        margin-bottom: 0.3rem;
        font-size: 0.8rem;
    }

    .stat-card strong {
        color: var(--text);
        font-size: 1.3rem;
        line-height: 1;
    }

    .stat-card--pending {
        background: linear-gradient(135deg, #f8f3ea 0%, #f6efe5 100%);
    }

    .users-table-shell {
        padding: 1rem;
    }

    .users-table-head {
        margin-bottom: 0.8rem;
    }

    .users-table-head h2 {
        margin: 0 0 0.2rem;
        color: var(--text);
        font-size: 1rem;
    }

    .users-table-head p {
        margin: 0;
        color: var(--muted);
        font-size: 0.82rem;
    }

    .users-table thead th {
        color: var(--muted);
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-bottom-color: var(--line);
    }

    .users-table tbody td {
        border-bottom-color: rgba(63, 110, 165, 0.08);
        padding-top: 0.78rem;
        padding-bottom: 0.78rem;
        font-size: 0.86rem;
        color: var(--text);
    }

    .user-cell {
        display: flex;
        gap: 0.75rem;
        align-items: center;
    }

    .user-avatar {
        width: 2.35rem;
        height: 2.35rem;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #84a8d1, #4f78a8);
        color: white;
        font-weight: 700;
        font-size: 0.9rem;
        flex-shrink: 0;
    }

    .user-name {
        color: var(--text);
        font-weight: 700;
        line-height: 1.3;
    }

    .user-email {
        color: var(--muted);
        font-size: 0.78rem;
    }

    .role-pill,
    .status-pill {
        display: inline-flex;
        align-items: center;
        padding: 0.28rem 0.55rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
    }

    .role-pill {
        background: #eef2f7;
        color: #5f728a;
    }

    .role-pill--admin {
        background: #dfeefd;
        color: #275c8f;
    }

    .role-pill--teacher {
        background: #f6efe5;
        color: #8b6842;
    }

    .role-pill--student {
        background: var(--accent-soft);
        color: var(--accent);
    }

    .status-pill {
        background: var(--accent-soft);
        color: var(--accent);
    }

    .status-pill--pending {
        background: #f6efe5;
        color: #8b6842;
    }

    .admin-danger-btn {
        background: #fff1f1;
        color: #b42318;
        border: 1px solid rgba(180, 35, 24, 0.1);
        border-radius: 999px;
        padding-inline: 0.9rem;
        font-size: 0.78rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .admin-danger-btn:hover,
    .admin-danger-btn:focus {
        background: #fff1f1;
        color: #b42318;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(180, 35, 24, 0.10);
    }

    .admin-empty-state {
        padding: 1.5rem;
        text-align: center;
        color: var(--muted);
    }

    @@media (max-width: 1100px) {
        .users-stats {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }

    @@media (max-width: 768px) {
        .users-stats {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @@media (max-width: 576px) {
        .users-stats {
            grid-template-columns: 1fr;
        }
    }
</style>
