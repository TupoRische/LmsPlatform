@using Core.ViewModels.Admin.Teachers
@model TeacherEditVm

<div class="teacher-edit-page mb-4">
    <div class="teacher-edit-shell">
        <div class="teacher-edit-head">
            <div>
                <span class="hero-kicker">Профил на учител</span>
                <h1>Редакция</h1>
                <p>Актуализирай основните данни за преподавателя и свързаното училище.</p>
            </div>
        </div>

        <form asp-action="Edit" method="post" class="teacher-edit-form">
            <input type="hidden" asp-for="Id" />

            <div class="form-grid">
                <div>
                    <label asp-for="FirstName" class="form-label">Име</label>
                    <input asp-for="FirstName" class="form-control form-control-lg" />
                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                </div>

                <div>
                    <label asp-for="LastName" class="form-label">Фамилия</label>
                    <input asp-for="LastName" class="form-control form-control-lg" />
                    <span asp-validation-for="LastName" class="text-danger small"></span>
                </div>

                <div class="form-span-2">
                    <label asp-for="Email" class="form-label">Имейл</label>
                    <input asp-for="Email" class="form-control form-control-lg" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="form-span-2">
                    <label asp-for="SchoolId" class="form-label">Училище</label>
                    <select asp-for="SchoolId" class="form-select form-select-lg">
                        @foreach (var school in Model.Schools)
                        {
                            <option value="@school.Id">@school.Name</option>
                        }
                    </select>
                    <span asp-validation-for="SchoolId" class="text-danger small"></span>
                </div>
            </div>

            <div class="teacher-edit-actions">
                <a asp-action="TeacherDetails" asp-route-id="@Model.Id" class="edit-link edit-link--soft">Назад</a>
                <button type="submit" class="edit-link">Запази</button>
            </div>
        </form>
    </div>
</div>

<style>
    .teacher-edit-page {
        --accent: #3f6ea5;
        --accent-soft: #edf4fb;
        --beige-soft: #f6efe5;
        --line: rgba(63, 110, 165, 0.12);
        --text: #28496f;
        --muted: #6f86a0;
    }

    .teacher-edit-shell {
        max-width: 1120px;
        margin: 0 auto;
        background: linear-gradient(135deg, #f4f8fc 0%, #f6efe5 100%);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 1.2rem 1.3rem;
        box-shadow: 0 10px 22px rgba(40, 73, 111, 0.04);
    }

    .hero-kicker {
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.68rem;
        font-weight: 700;
        color: var(--accent);
        margin-bottom: 0.4rem;
    }

    .teacher-edit-head h1 {
        margin: 0 0 0.25rem;
        color: var(--text);
        font-size: clamp(1.45rem, 2vw, 1.9rem);
    }

    .teacher-edit-head p {
        margin: 0 0 1rem;
        color: var(--muted);
        font-size: 0.88rem;
        line-height: 1.5;
        max-width: 760px;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem;
    }

    .form-span-2 {
        grid-column: 1 / -1;
    }

    .form-label {
        color: var(--text);
        font-weight: 700;
        margin-bottom: 0.4rem;
    }

    .teacher-edit-form .form-control,
    .teacher-edit-form .form-select {
        border-radius: 14px;
        border-color: rgba(63, 110, 165, 0.14);
        padding: 0.72rem 0.9rem;
        box-shadow: none;
    }

    .teacher-edit-actions {
        display: flex;
        gap: 0.55rem;
        justify-content: flex-end;
        margin-top: 1rem;
    }

    .edit-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 96px;
        padding: 0.58rem 0.82rem;
        border: none;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.82rem;
        background: var(--accent);
        color: white;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .edit-link:hover,
    .edit-link:focus {
        background: var(--accent);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(40, 73, 111, 0.14);
    }

    .edit-link--soft {
        background: var(--accent-soft);
        color: var(--accent);
    }

    .edit-link--soft:hover,
    .edit-link--soft:focus {
        background: var(--accent-soft);
        color: var(--accent);
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(40, 73, 111, 0.10);
    }

    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
