@using Core.ViewModels.Admin.Teachers
@model IEnumerable<TeacherMaterialVm>

<h2>Материали</h2>

<table class="table">
    <thead>
        <tr>
            <th>Заглавие</th>
            <th>Описание</th>
            <th>Професия</th>
            <th>Категория</th>
            <th>Дата</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model)
        {
            <tr>
                <td>@m.Title</td>
                <td>@m.Description</td>
                <td>@m.Profession</td>
                <td>@m.Category</td>
                <td>@m.CreatedOn.ToShortDateString()</td>
                <td>
                    <a asp-action="MaterialDetails"
                       asp-route-id="@m.Id"
                       class="btn btn-sm btn-info"> 
                        Детайли
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>