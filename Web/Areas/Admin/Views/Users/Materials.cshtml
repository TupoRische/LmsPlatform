@using Core.ViewModels.Admin.Teachers
@model IEnumerable<TeacherMaterialVm>

<div class="teacher-materials-page mb-4">
    <div class="materials-hero">
        <div>
            <span class="hero-kicker">Учителски профил</span>
            <h1>Материали на преподавателя</h1>
            <p>Всички публикувани от този учител ресурси на едно място, с професия, категория и дата на добавяне.</p>
        </div>

        <a asp-action="Teachers" class="hero-link">Назад към учителите</a>
    </div>

    @if (!Model.Any())
    {
        <div class="admin-empty-state">Този учител все още няма публикувани материали.</div>
    }
    else
    {
        <div class="teacher-materials-grid">
            @foreach (var material in Model)
            {
                <article class="teacher-material-card">
                    <span class="teacher-material-meta">@material.Profession · @material.Category</span>
                    <h3>@material.Title</h3>
                    <p>@(string.IsNullOrWhiteSpace(material.Description) ? "Няма добавено описание за този материал." : material.Description)</p>

                    <div class="teacher-material-footer">
                        <span class="teacher-material-date">Публикувано: @material.CreatedOn.ToString("dd.MM.yyyy")</span>
                        <a asp-area=""
                           asp-controller="Materials"
                           asp-action="Details"
                           asp-route-id="@material.Id"
                           class="teacher-material-link">
                            Детайли
                        </a>
                    </div>
                </article>
            }
        </div>
    }
</div>

<style>
    .teacher-materials-page {
        --accent: #3f6ea5;
        --accent-soft: #edf4fb;
        --beige-soft: #f6efe5;
        --line: rgba(63, 110, 165, 0.12);
        --text: #28496f;
        --muted: #6f86a0;
    }

    .materials-hero,
    .teacher-material-card,
    .admin-empty-state {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 18px;
        box-shadow: 0 10px 22px rgba(40, 73, 111, 0.04);
    }

    .materials-hero {
        background: linear-gradient(135deg, #f4f8fc 0%, #f6efe5 100%);
        padding: 1.15rem 1.25rem;
        min-height: 148px;
        display: flex;
        justify-content: space-between;
        gap: 0.9rem;
        align-items: center;
        margin-bottom: 1rem;
    }

    .hero-kicker {
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.68rem;
        font-weight: 700;
        color: var(--accent);
        margin-bottom: 0.4rem;
    }

    .materials-hero h1 {
        margin: 0 0 0.25rem;
        color: var(--text);
        font-size: clamp(1.45rem, 2vw, 1.9rem);
    }

    .materials-hero p {
        margin: 0;
        max-width: 760px;
        color: var(--muted);
        line-height: 1.5;
        font-size: 0.88rem;
    }

    .hero-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.58rem 0.82rem;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.82rem;
        white-space: nowrap;
        background: #5c85b1;
        color: white;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .hero-link:hover,
    .hero-link:focus {
        background: var(--accent);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(40, 73, 111, 0.14);
    }

    .teacher-materials-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 380px));
        gap: 0.85rem;
        justify-content: start;
    }

    .teacher-material-card {
        padding: 0.95rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
    }

    .teacher-material-meta {
        display: inline-block;
        color: var(--muted);
        font-size: 0.76rem;
    }

    .teacher-material-card h3 {
        margin: 0;
        color: var(--text);
        font-size: 1rem;
        line-height: 1.35;
    }

    .teacher-material-card p {
        margin: 0;
        color: var(--muted);
        line-height: 1.55;
        font-size: 0.86rem;
        min-height: 2.8rem;
    }

    .teacher-material-footer {
        margin-top: auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.7rem;
        padding-top: 0.2rem;
    }

    .teacher-material-date {
        color: var(--muted);
        font-size: 0.76rem;
    }

    .teacher-material-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.58rem 0.82rem;
        border-radius: 999px;
        text-decoration: none;
        font-weight: 700;
        font-size: 0.82rem;
        background: var(--accent-soft);
        color: var(--accent);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .teacher-material-link:hover,
    .teacher-material-link:focus {
        background: var(--accent-soft);
        color: var(--accent);
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(40, 73, 111, 0.10);
    }

    .admin-empty-state {
        padding: 1.5rem;
        text-align: center;
        color: var(--muted);
    }

    @@media (max-width: 768px) {
        .materials-hero {
            flex-direction: column;
            align-items: flex-start;
        }

        .teacher-materials-grid {
            grid-template-columns: 1fr;
        }

        .teacher-material-footer {
            flex-direction: column;
            align-items: stretch;
        }
    }
</style>
