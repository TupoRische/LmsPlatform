@using Core.ViewModels.Admin.Teachers
@model IEnumerable<TeacherListVm>

<h2>Учители</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Име</th>
            <th>Училище</th>
            <th>Материали</th>
            <th>Детайли</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var teacher in Model)
        {
            <tr>
                <td>@teacher.FullName</td>

                <td>@teacher.School</td>

                <td>
                    <a asp-controller="Materials"
                       asp-action="ByTeacher"
                       asp-route-id="@teacher.Id"
                       class="btn btn-sm btn-primary">
                        Материали
                    </a>
                </td>

                <td>
                    <a asp-action="TeacherDetails"
                       asp-route-id="@teacher.Id"
                       class="btn btn-sm btn-secondary">
                        Детайли
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>