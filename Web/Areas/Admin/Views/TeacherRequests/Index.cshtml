@model Core.ViewModels.Admin.TeacherRequests.TeacherRequestsPageVm

<h2>Заявки за учител</h2>
<hr />

@if (!Model.Requests.Any())
{
    <div class="alert alert-info">Няма чакащи заявки.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Име</th>
                <th>Email</th>
                <th>Дата</th>
                <th class="text-end"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model.Requests)
            {
                <tr>
                    <td>@u.FullName</td>
                    <td>@u.Email</td>
                    <td>@u.CreatedOn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    <td class="text-end">
                        <form class="d-inline" method="post" asp-action="Approve">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@u.Id" />
                            <button class="btn btn-sm btn-success">Approve</button>
                        </form>

                        <form class="d-inline" method="post" asp-action="Reject">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@u.Id" />
                            <button class="btn btn-sm btn-outline-danger">Reject</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}