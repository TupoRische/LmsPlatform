@model Core.ViewModels.Admin.TeacherRequests.TeacherRequestsPageVm

<div class="requests-page mb-4">
    @{
        var requestsLabel = Model.Requests.Count == 1 ? "заявка" : "заявки";
    }

    <div class="requests-hero">
        <div>
            <span class="hero-kicker">Админ панел</span>
            <h1>Заявки за учител</h1>
            <p>Опашка за одобрение на потребители, които искат да публикуват материали като преподаватели.</p>
        </div>

        <div class="requests-badge">
            @Model.Requests.Count @requestsLabel
        </div>
    </div>

    @if (!Model.Requests.Any())
    {
        <div class="admin-empty-state">Няма чакащи заявки.</div>
    }
    else
    {
        <div class="requests-list">
            @foreach (var u in Model.Requests)
            {
                <article class="request-card">
                    <div class="request-card__meta">
                        <div class="request-avatar">
                            @(string.IsNullOrWhiteSpace(u.FullName) ? "?" : u.FullName[..1].ToUpperInvariant())
                        </div>

                        <div>
                            <h3>@u.FullName</h3>
                            <p>@u.Email</p>
                        </div>
                    </div>

                    <div class="request-card__date">
                        Подадена на @u.CreatedOn.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                    </div>

                    <div class="request-card__actions">
                        <form method="post" asp-action="Approve">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@u.Id" />
                            <button class="request-btn request-btn--approve">Одобри</button>
                        </form>

                        <form method="post" asp-action="Reject">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@u.Id" />
                            <button class="request-btn request-btn--reject">Отхвърли</button>
                        </form>
                    </div>
                </article>
            }
        </div>
    }
</div>

<style>
    .requests-page {
        --accent: #3f6ea5;
        --accent-soft: #edf4fb;
        --beige-soft: #f6efe5;
        --line: rgba(63, 110, 165, 0.12);
        --text: #28496f;
        --muted: #6f86a0;
    }

    .requests-hero,
    .request-card,
    .admin-empty-state {
        border-radius: 18px;
        border: 1px solid var(--line);
        box-shadow: 0 10px 22px rgba(40, 73, 111, 0.04);
    }

    .requests-hero {
        background: linear-gradient(135deg, #f4f8fc 0%, #f6efe5 100%);
        padding: 1.15rem 1.25rem;
        display: flex;
        justify-content: space-between;
        gap: 0.9rem;
        align-items: center;
        min-height: 148px;
        margin-bottom: 1rem;
    }

    .hero-kicker {
        display: inline-block;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.68rem;
        font-weight: 700;
        color: var(--accent);
        margin-bottom: 0.4rem;
    }

    .requests-hero h1 {
        margin: 0 0 0.25rem;
        color: var(--text);
        font-size: clamp(1.45rem, 2vw, 1.9rem);
    }

    .requests-hero p {
        margin: 0;
        color: var(--muted);
        max-width: 760px;
        line-height: 1.5;
        font-size: 0.88rem;
    }

    .requests-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 118px;
        padding: 0.48rem 0.7rem;
        border-radius: 999px;
        background: var(--beige-soft);
        color: #8b6842;
        font-weight: 700;
        font-size: 0.78rem;
    }

    .requests-list {
        display: grid;
        gap: 0.75rem;
    }

    .request-card {
        background: #fff;
        padding: 0.85rem 0.95rem;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto auto;
        gap: 0.75rem;
        align-items: center;
    }

    .request-card__meta {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .request-avatar {
        width: 2.45rem;
        height: 2.45rem;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #7ea4d3, #4f78a8);
        color: white;
        font-weight: 700;
        flex-shrink: 0;
    }

    .request-card h3 {
        margin: 0 0 0.25rem;
        color: var(--text);
        font-size: 0.94rem;
    }

    .request-card p,
    .request-card__date {
        margin: 0;
        color: var(--muted);
        font-size: 0.82rem;
    }

    .request-card__actions {
        display: flex;
        gap: 0.5rem;
    }

    .request-btn {
        border: none;
        border-radius: 999px;
        padding: 0.56rem 0.78rem;
        font-weight: 700;
        font-size: 0.8rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .request-btn--approve {
        background: var(--accent);
        color: white;
    }

    .request-btn--approve:hover,
    .request-btn--approve:focus {
        background: var(--accent);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(40, 73, 111, 0.14);
    }

    .request-btn--reject {
        background: #fff1f1;
        color: #b42318;
    }

    .request-btn--reject:hover,
    .request-btn--reject:focus {
        background: #fff1f1;
        color: #b42318;
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(180, 35, 24, 0.10);
    }

    .admin-empty-state {
        background: #fff;
        padding: 1.5rem;
        text-align: center;
        color: var(--muted);
    }

    @@media (max-width: 992px) {
        .request-card {
            grid-template-columns: 1fr;
            align-items: start;
        }
    }

    @@media (max-width: 576px) {
        .requests-hero,
        .request-card__actions {
            flex-direction: column;
            align-items: stretch;
        }
    }
</style>
