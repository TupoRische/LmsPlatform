@model IEnumerable<Core.ViewModels.School.SchoolListVm>

<div class="schools-page mb-4">
    <div class="schools-hero">
        <div>
            <span class="hero-kicker">Админ панел</span>
            <h1>Училища</h1>
            <p>Преглед на училищата, които захранват професиите и профилите в системата.</p>
        </div>

        <a class="hero-link"
           asp-area="Admin"
           asp-controller="Schools"
           asp-action="Create">
            Добави училище
        </a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-4 mb-4">
            @TempData["Error"]
        </div>
    }

    @if (!Model.Any())
    {
        <div class="admin-empty-state">Все още няма добавени училища.</div>
    }
    else
    {
        <div class="schools-grid">
            @foreach (var school in Model)
            {
                var professionsLabel = school.ProfessionsCount == 1 ? "професия" : "професии";
                var usersLabel = school.UsersCount == 1 ? "потребител" : "потребители";

                <article class="school-card">
                    <div class="school-card__head">
                        <span class="school-city">@school.City</span>
                        <h3>@school.Name</h3>
                    </div>

                    <div class="school-metrics">
                        <div class="school-metric">
                            <strong>@school.ProfessionsCount</strong>
                            <span>@professionsLabel</span>
                        </div>
                        <div class="school-metric">
                            <strong>@school.UsersCount</strong>
                            <span>@usersLabel</span>
                        </div>
                    </div>

                    <div class="school-actions">
                        <a class="school-link school-link--soft"
                           asp-area="Admin"
                           asp-controller="Schools"
                           asp-action="Edit"
                           asp-route-id="@school.Id">
                            Редактирай
                        </a>

                        <a class="school-link"
                           asp-area="Admin"
                           asp-controller="Schools"
                           asp-action="Delete"
                           asp-route-id="@school.Id">
                            Изтрий
                        </a>
                    </div>
                </article>
            }
        </div>
    }
</div>

<style>
