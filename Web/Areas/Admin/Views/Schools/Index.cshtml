@model IEnumerable<Core.ViewModels.School.SchoolListVm>

<h2>Училища</h2>

<p>
    <a class="btn btn-primary" asp-area="Admin" asp-controller="Schools" asp-action="Create">
        + Ново училище
    </a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Име</th>
            <th>Град</th>
            <th>Професии</th>
            <th>Потребители</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.Name</td>
                <td>@s.City</td>
                <td>@s.ProfessionsCount</td>
                <td>@s.UsersCount</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-secondary"
                       asp-area="Admin" asp-controller="Schools" asp-action="Edit" asp-route-id="@s.Id">Edit</a>

                    <a class="btn btn-sm btn-outline-danger"
                       asp-area="Admin" asp-controller="Schools" asp-action="Delete" asp-route-id="@s.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
