@using Core.ViewModels.Comments
@model IEnumerable<CommentListVm>

<h3>Разговор за материала</h3>

<div class="list-group">
    @foreach (var comment in Model)
    {
        <div class="list-group-item mb-3 shadow-sm border-start border-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <span class="fw-bold">@comment.AuthorName</span>
                    <span class="badge @(comment.Role == "Admin" ? "bg-primary" : "bg-info") ms-2">@comment.Role</span>
                    <p class="mt-2 mb-1">@comment.Content</p>
                    <small class="text-muted">@comment.CreatedOn.ToString("g")</small>
                </div>

                <form asp-action="Delete" method="post" onsubmit="return confirm('Сигурни ли сте?');">
                    <input type="hidden" name="commentId" value="@comment.Id" />
                    <input type="hidden" name="materialId" value="@ViewContext.RouteData.Values["materialId"]" />
                    <button type="submit" class="btn btn-sm btn-outline-danger">
                        <i class="bi bi-trash"></i> Изтрий
                    </button>
                </form>
            </div>
        </div>
    }
</div>