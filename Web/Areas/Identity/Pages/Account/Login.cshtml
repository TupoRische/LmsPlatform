@page
@model LoginModel

@{
    ViewData["Title"] = "Влезте в профил";
}

<section class="auth-page">
    <div class="auth-shell auth-shell--single">
        <section class="auth-carrd">
            <span class="auth-chip">Добре дошли обратно</span>
            <h1 class="auth-title">@ViewData["Title"]</h1>
            <p class="auth-subtitle">Използвайте имейла и паролата, с които сте се регистрирали.</p>

            <form id="account" method="post" asp-route-returnUrl="@Model.ReturnUrl" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="text-danger auth-validation-summary" role="alert"></div>

                <div class="auth-field">
                    <label asp-for="Input.Email" class="form-label">Имейл</label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.Password" class="form-label">Парола</label>
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Въведете парола" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <label asp-for="Input.RememberMe" class="auth-checkbox">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <span>@Html.DisplayNameFor(m => m.Input.RememberMe)</span>
                </label>

                <button id="login-submit" type="submit" class="btn btn-primary auth-submit" style="background: #6482AD !important;">Влез</button>

                <div class="auth-link-row">
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Нямате профил? Създайте регистрация</a>
                    <a asp-area="" asp-controller="Home" asp-action="Index">Към началната страница</a>
                </div>
            </form>
        </section>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
