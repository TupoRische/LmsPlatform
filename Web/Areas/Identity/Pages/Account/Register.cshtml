@page
@model RegisterModel
@{
    ViewData["Title"] = "Регистрация";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="auth-page">
    <div class="auth-shell auth-shell--single">
        <section class="auth-carrd">
            <span class="auth-chip">Създай нов акаунт</span>
            <h1 class="auth-title">@ViewData["Title"]</h1>
            <p class="auth-subtitle">Попълнете данните си и изберете какъв тип профил желаете.</p>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="auth-form">
                <div asp-validation-summary="ModelOnly" class="text-danger auth-validation-summary" role="alert"></div>

                <div class="auth-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="auth-field">
                        <label asp-for="Input.FirstName" class="form-label">Име</label>
                        <input asp-for="Input.FirstName" class="form-control" aria-required="true" placeholder="Име" />
                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="Input.LastName" class="form-label">Фамилия</label>
                        <input asp-for="Input.LastName" class="form-control" aria-required="true" placeholder="Фамилия" />
                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                    </div>
                </div>

                <div class="auth-field">
                    <label asp-for="Input.SchoolId" class="form-label">Училище</label>
                    <select asp-for="Input.SchoolId" class="form-select" asp-items="Model.Schools" style="width: 100%; padding: 0.6rem; border-radius: 8px; border: 1px solid #dee2e6;">
                        <option value="">Избери училище</option>
                    </select>
                    <span asp-validation-for="Input.SchoolId" class="text-danger"></span>
                </div>

                <label asp-for="Input.RequestTeacher" class="auth-check-card" style="display: block; background: #f8f9fa; padding: 1rem; border-radius: 12px; cursor: pointer; border: 1px solid #eee;">
                    <span class="auth-check-card-main" style="display: flex; gap: 10px; align-items: flex-start;">
                        <input asp-for="Input.RequestTeacher" class="form-check-input" style="margin-top: 4px;" />
                        <span>
                            <strong style="display: block; color: #28496f;">Искам да се регистрирам като учител</strong>
                            <small style="color: #6c757d; font-size: 0.8rem;">Профилът ще изчака одобрение за пълен достъп.</small>
                        </span>
                    </span>
                </label>

                <div class="auth-field">
                    <label asp-for="Input.Email" class="form-label">Имейл</label>
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="auth-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
                    <div class="auth-field">
                        <label asp-for="Input.Password" class="form-label">Парола</label>
                        <input asp-for="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Парола" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="auth-field">
                        <label asp-for="Input.ConfirmPassword" class="form-label">Потвърди</label>
                        <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Повтори" />
                        <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>
                <button id="registerSubmit" type="submit" class="btn btn-primary auth-submit" style="background: #6482AD !important; width: 100%; margin-top: 1.5rem; padding: 0.8rem; border-radius: 999px; border: none; font-weight: bold; color: white;">Регистрирай се</button>

                <div class="auth-link-row">
                    <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl">Вече имате профил? Влезте тук</a>
                    <a asp-area="" asp-controller="Home" asp-action="Index">Към началната страница</a>
                </div>
            </form>
        </section>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}