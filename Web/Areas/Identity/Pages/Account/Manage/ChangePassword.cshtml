@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Промяна на парола";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<section class="auth-page">
    <div class="auth-shell auth-shell--single">
        <section class="auth-carrd">
            <span class="auth-chip">Сигурност</span>
            <h1 class="auth-title">Промяна на парола</h1>
            <p class="auth-subtitle">Въведете текущата и новата си парола, за да я промените.</p>

            <partial name="_StatusMessage" for="StatusMessage" />
            
            <form id="change-password-form" method="post" class="auth-form mt-2">
                <div asp-validation-summary="ModelOnly" class="text-danger auth-validation-summary" role="alert"></div>
                
                <div class="auth-field">
                    <label asp-for="Input.OldPassword" class="form-label">Текуща парола</label>
                    <input asp-for="Input.OldPassword" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Въведете текуща парола" />
                    <span asp-validation-for="Input.OldPassword" class="text-danger"></span>
                </div>
                
                <div class="auth-field">
                    <label asp-for="Input.NewPassword" class="form-label">Нова парола</label>
                    <input asp-for="Input.NewPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Въведете нова парола" />
                    <span asp-validation-for="Input.NewPassword" class="text-danger"></span>
                </div>
                
                <div class="auth-field">
                    <label asp-for="Input.ConfirmPassword" class="form-label">Потвърдете паролата</label>
                    <input asp-for="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="Потвърдете новата парола" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="auth-actions mt-4 text-center">
                    <button type="submit" class="btn btn-primary auth-submit w-100" style="background: #314c73 !important; border: none; padding: 12px; border-radius: 8px;">Запази паролата</button>
                </div>
                
                <div class="auth-link-row mt-3 text-center">
                    <a asp-page="./Index" style="color: #6482ad; text-decoration: none;">Обратно към Профил</a>
                </div>
            </form>
        </section>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
