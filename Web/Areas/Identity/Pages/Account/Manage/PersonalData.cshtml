@page
@model PersonalDataModel
@{
    ViewData["Title"] = "Лични данни";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<section class="auth-page">
    <div class="auth-shell auth-shell--single">
        <section class="auth-carrd">
            <span class="auth-chip">Лични данни</span>
            <h1 class="auth-title">Вашите лични данни</h1>

            <div class="auth-form" style="gap: 24px;">
                <div style="padding: 20px; border-radius: 18px; border: 1px solid rgba(100,130,173,0.2); background: rgba(255,255,255,0.68);">
                    <h3 style="color: #314c73; font-size: 1.1rem; margin: 0 0 8px;">Изтегляне на данни</h3>
                    <p style="color: #51657f; font-size: 0.95rem; margin: 0 0 14px;">Изтеглете копие на личните данни, съхранявани за вас в платформата.</p>
                    <form asp-page="./DownloadPersonalData" method="post">
                        <button class="btn auth-submit" type="submit" style="max-width: 260px; min-height: 44px; font-size: 0.9rem;">
                            <i class="bi bi-download me-2"></i>Изтегли данните ми
                        </button>
                    </form>
                </div>

                <div style="padding: 20px; border-radius: 18px; border: 1px solid rgba(220,53,69,0.2); background: rgba(220,53,69,0.04);">
                    <h3 style="color: #dc3545; font-size: 1.1rem; margin: 0 0 8px;">Изтриване на акаунт</h3>
                    <p style="color: #51657f; font-size: 0.95rem; margin: 0 0 14px;">Внимание: Изтриването на акаунта е необратимо действие.</p>
                    <a asp-page="./DeletePersonalData" class="btn" style="max-width: 260px; min-height: 44px; font-size: 0.9rem; background: #dc3545; color: white; border-radius: 18px; display: inline-flex; align-items: center; justify-content: center; text-decoration: none;">
                        <i class="bi bi-trash me-2"></i>Изтрий акаунта ми
                    </a>
                </div>

                <div class="auth-link-row mt-2" style="justify-content: center;">
                    <a asp-page="./Index" style="color: #6482ad; text-decoration: none; font-weight: 600;">← Обратно към Профил</a>
                </div>
            </div>
        </section>
    </div>
</section>
