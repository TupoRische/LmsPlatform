@using Core.ViewModels.Professions
@model ProfessionDetailsVm

<h2 class="mb-2">@Model.Name</h2>
<div class="text-muted mb-3">Училище: @Model.SchoolName</div>

@if (!string.IsNullOrWhiteSpace(Model.Description))
{
    <p>@Model.Description</p>
}
else
{
    <p class="text-muted">Няма описание.</p>
}

<hr class="my-4" />

<div class="presentation-section">
    <h4 style="text-align: center" class="mb-3">Детайли за професията (Презентация)</h4>

    <div class="pdf-container page-container">
        @* Използваме ID-то на модела за име на файла *@
        <iframe src="/presentations/@(Model.Id).pdf#toolbar=0&navpanes=0"
                type="application/pdf"
                width="100%"
                height="500px">
            @* <p>
                Вашият браузър не поддържа вграждане на PDF файлове.
                <a href="/presentations/@(Model.Id).pdf">Кликнете тук, за да изтеглите презентацията.</a>
            </p> *@
        </iframe>
    </div>
</div>

<div class="mt-4">
    <a class="btn btn-outline-secondary" asp-controller="Professions" asp-action="Index">Назад</a>
</div>


<style>
    /* Стилизираме контейнера на презентацията */
    .pdf-container {
        width: 100%;
        max-width: 1100px;
        margin: 0 auto;
        border: 1px solid #dee2e6;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        background-color: #f8f9fa;
    }

    .pdf-container iframe {
        display: block;
        border: none;
    }

    /* Адаптивност за мобилни устройства */
    @@media (max-width: 768px) {
        .pdf-container {
            height: 400px;
        }
        .pdf-container iframe {
            height: 400px;
        }
    }
</style>